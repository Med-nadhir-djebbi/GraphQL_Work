generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
}
model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     Role   @default(USER)
  cvs      Cv[]
}

model Cv {
  id      Int    @id @default(autoincrement())
  job     String
  title   String
  age     Int
  user    User   @relation(fields: [userId], references: [id])
  userId  Int
  skills  CvSkill[]
}

model Skill {
  id   Int    @id @default(autoincrement())
  name String @unique

  cvs  CvSkill[]
}

model CvSkill {
  cvId    Int
  skillId Int

  cv      Cv    @relation(fields: [cvId], references: [id], onDelete: Cascade)
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([cvId, skillId])
}

enum Role {
  USER
  ADMIN
}